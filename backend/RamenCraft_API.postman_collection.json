{
	"info": {
		"_postman_id": "ramencraft-api-collection",
		"name": "RamenCraft API",
		"description": "Full REST API collection for the RamenCraft ramen-building game.\n\nBase URL: http://localhost:8000\n\nResources:\n- Auth (register, login, me)\n- Categories (paginated + search)\n- Ingredients (full CRUD + filtering)\n- Pairings (full CRUD + search)\n- Achievements (CRUD + user achievements + check)\n- Users (read, update, delete + filtering)\n- Bowls (serve + history)\n- Favorites (CRUD)\n- Nutrition (external API + seed)\n- Leaderboard (paginated + search)\n\nRun Auth first to get a token, then run other folders.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8000", "type": "string" },
		{ "key": "token", "value": "", "type": "string" },
		{ "key": "admin_token", "value": "", "type": "string" },
		{ "key": "user_id", "value": "", "type": "string" },
		{ "key": "created_ingredient_id", "value": "", "type": "string" },
		{ "key": "created_pairing_id", "value": "", "type": "string" },
		{ "key": "created_achievement_id", "value": "", "type": "string" },
		{ "key": "created_favorite_id", "value": "", "type": "string" },
		{ "key": "bowl_id", "value": "", "type": "string" }
	],
	"item": [
		{
			"name": "1. Auth",
			"item": [
				{
					"name": "Register",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 201', () => pm.response.to.have.status(201));",
						"const json = pm.response.json();",
						"pm.test('Has user and token', () => { pm.expect(json.user).to.be.an('object'); pm.expect(json.token).to.be.a('string'); });",
						"pm.collectionVariables.set('token', json.token);",
						"pm.collectionVariables.set('user_id', json.user.id);"
					] } }],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"username\": \"postman_test\",\n  \"email\": \"postman@test.com\",\n  \"password\": \"test123\"\n}" },
						"url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] }
					}
				},
				{
					"name": "Login",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"const json = pm.response.json();",
						"pm.test('Has token', () => pm.expect(json.token).to.be.a('string'));",
						"pm.collectionVariables.set('token', json.token);"
					] } }],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"email\": \"postman@test.com\",\n  \"password\": \"test123\"\n}" },
						"url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] }
					}
				},
				{
					"name": "Login as Admin",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"const json = pm.response.json();",
						"pm.collectionVariables.set('admin_token', json.token);"
					] } }],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@ramencraft.com\",\n  \"password\": \"password123\"\n}" },
						"url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] }
					}
				},
				{
					"name": "Get Me",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Has username and totalXp', () => { const json = pm.response.json(); pm.expect(json.username).to.be.a('string'); pm.expect(json.totalXp).to.be.a('number'); });"
					] } }],
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": { "raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api", "auth", "me"] }
					}
				}
			]
		},
