								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has pagination structure', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('data');",
									"    pm.expect(json).to.have.property('page');",
									"    pm.expect(json).to.have.property('limit');",
									"    pm.expect(json).to.have.property('total');",
									"});",
									"",
									"pm.test('Data is an array', function () {",
									"    pm.expect(pm.response.json().data).to.be.an('array');",
									"});",
									"",
									"pm.test('Each ingredient has required fields', function () {",
									"    const data = pm.response.json().data;",
									"    if (data.length > 0) {",
									"        data.forEach(function (ing) {",
									"            pm.expect(ing).to.have.property('id');",
									"            pm.expect(ing).to.have.property('name');",
									"            pm.expect(ing).to.have.property('categoryId');",
									"            pm.expect(ing).to.have.property('categoryName');",
									"            pm.expect(ing).to.have.property('isAvailable');",
									"        });",
									"    }",
									"});",
									"",
									"pm.test('Pagination values are correct', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.page).to.eql(1);",
									"    pm.expect(json.limit).to.eql(10);",
									"    pm.expect(json.total).to.be.a('number');",
									"});"
								],
								"type": "text/javascript"
							}
