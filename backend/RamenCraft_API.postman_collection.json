{
	"info": {
		"_postman_id": "ramencraft-api-collection",
		"name": "RamenCraft API",
		"description": "Full REST API collection for the RamenCraft ramen-building game.\n\nBase URL: http://localhost:8000\n\nResources:\n- Categories (read-only)\n- Ingredients (full CRUD)\n- Pairings (full CRUD)\n- Achievements (full CRUD)\n- Users (read, update, delete)\n- Leaderboard (read-only)\n\nRun the folders in order (top to bottom) — CRUD flows use collection variables to pass created IDs between requests.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "created_ingredient_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "created_pairing_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "created_achievement_id",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Categories",
			"item": [
				{
					"name": "Get All Categories",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response is a non-empty array', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.be.an('array').that.is.not.empty;",
									"});",
									"",
									"pm.test('Each category has required fields', function () {",
									"    const json = pm.response.json();",
									"    json.forEach(function (cat) {",
									"        pm.expect(cat).to.have.property('id');",
									"        pm.expect(cat).to.have.property('name');",
									"        pm.expect(cat).to.have.property('displayName');",
									"        pm.expect(cat).to.have.property('sortOrder');",
									"    });",
									"});",
									"",
									"pm.test('There are exactly 5 categories', function () {",
									"    pm.expect(pm.response.json().length).to.eql(5);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/categories",
							"host": ["{{base_url}}"],
							"path": ["api", "categories"]
						},
						"description": "Returns all ingredient categories sorted by display order."
					}
				}
			]
		},
		{
